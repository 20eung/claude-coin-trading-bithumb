# === 거래소 (Bithumb) ===
BITHUMB_ACCESS_KEY=your_bithumb_access_key
BITHUMB_SECRET_KEY=your_bithumb_secret_key

# === 데이터 수집 ===
TAVILY_API_KEY=tvly-your_tavily_api_key

# === 데이터베이스 ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_URL=postgresql://postgres.[your-project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# === 알림 ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_THREAD_ID=your_telegram_thread_id

# === 안전장치 ===
DRY_RUN=true
MAX_TRADE_AMOUNT=100000
MAX_DAILY_TRADES=3
MAX_POSITION_RATIO=0.5
MIN_TRADE_INTERVAL_HOURS=4
EMERGENCY_STOP=false
